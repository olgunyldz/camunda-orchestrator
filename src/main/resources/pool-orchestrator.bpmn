<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  targetNamespace="http://bpmn.io/schema/bpmn"
  id="Definitions_1">

  <!--
    Her pool task'ı asyncBefore=true ile kuyruğa alınır.
    Exception fırlatıldığında Camunda failedJobRetryTimeCycle'a göre otomatik retry yapar.
    Tüm denemeler tükenince Cockpit'te Incident oluşur.
    Her delegate kendi "Required" değişkenini kontrol eder; gerekli değilse direkt döner.
  -->
  <bpmn:process id="MainPoolProcess" name="Kredi Başvuru Havuz Orkestratörü"
                isExecutable="true" camunda:historyTimeToLive="30">

    <bpmn:startEvent id="start" name="Başvuru Alındı">
      <bpmn:outgoing>sf1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:sequenceFlow id="sf1" sourceRef="start" targetRef="routeTask"/>

    <!-- Senkron: segment bazlı değişkenleri set eder -->
    <bpmn:serviceTask id="routeTask" name="Yönlendirme"
                      camunda:delegateExpression="${poolRouterDelegate}">
      <bpmn:incoming>sf1</bpmn:incoming>
      <bpmn:outgoing>sf2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sequenceFlow id="sf2" sourceRef="routeTask" targetRef="kbsTask"/>

    <!-- Async: exception → Camunda retry (R3/PT10S = 3 deneme, 10sn arayla) -->
    <bpmn:serviceTask id="kbsTask" name="KBS Havuzu"
                      camunda:asyncBefore="true"
                      camunda:failedJobRetryTimeCycle="R3/PT10S"
                      camunda:delegateExpression="${kbsPoolDelegate}">
      <bpmn:incoming>sf2</bpmn:incoming>
      <bpmn:outgoing>sf3</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sequenceFlow id="sf3" sourceRef="kbsTask" targetRef="lksTask"/>

    <bpmn:serviceTask id="lksTask" name="LKS Havuzu"
                      camunda:asyncBefore="true"
                      camunda:failedJobRetryTimeCycle="R3/PT10S"
                      camunda:delegateExpression="${lksKontrolDelegate}">
      <bpmn:incoming>sf3</bpmn:incoming>
      <bpmn:outgoing>sf4</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sequenceFlow id="sf4" sourceRef="lksTask" targetRef="tbhTask"/>

    <bpmn:serviceTask id="tbhTask" name="TBH Havuzu"
                      camunda:asyncBefore="true"
                      camunda:failedJobRetryTimeCycle="R3/PT10S"
                      camunda:delegateExpression="${tbhKontrolDelegate}">
      <bpmn:incoming>sf4</bpmn:incoming>
      <bpmn:outgoing>sf5</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sequenceFlow id="sf5" sourceRef="tbhTask" targetRef="finishTask"/>

    <bpmn:serviceTask id="finishTask" name="Tamamla"
                      camunda:expression="${execution.setVariable('status','DONE')}">
      <bpmn:incoming>sf5</bpmn:incoming>
      <bpmn:outgoing>sf6</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sequenceFlow id="sf6" sourceRef="finishTask" targetRef="end"/>

    <bpmn:endEvent id="end" name="Süreç Tamamlandı">
      <bpmn:incoming>sf6</bpmn:incoming>
    </bpmn:endEvent>

  </bpmn:process>

</bpmn:definitions>
